# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to GitHub — .gitignore already excludes it.

# Your MongoDB Atlas connection string.
# Get this from Atlas -> Database -> Connect -> "Drivers" -> copy the string,
# then replace <password> with your real database user password.
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@yourcluster.mongodb.net/eyries?retryWrites=true&w=majority

# Any long random string — used to sign login session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# First-run admin account, used only by the seed script (npm run seed).
# Change this password after your first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeThisPassword123
